{
  "name": "vector-migrate",
  "version": "1.0.0",
  "description": "Interactive, zero-token CLI that migrates Azure DevOps repositories to GitHub, preserving full commit history and rewriting author identities so the contribution graph stays intact.",
  "type": "module",
  "bin": {
    "vector-migrate": "bin/index.js"
  },
  "exports": {
    ".": "./src/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "migrate.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./bin/index.js",
    "check": "node ./bin/index.js --check",
    "test": "node --test tests/*.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "azure-devops",
    "github",
    "git",
    "migration",
    "git-filter-repo",
    "contribution-graph",
    "cli",
    "ssh",
    "mailmap"
  ],
  "author": "Vector contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YRACHEK101/Vector.git"
  },
  "homepage": "https://github.com/YRACHEK101/Vector#readme",
  "bugs": {
    "url": "https://github.com/YRACHEK101/Vector/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1"
  }
}
